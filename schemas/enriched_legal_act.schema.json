{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EnrichedDocument",
  "type": "object",
  "required": ["legal_act"],
  "properties": {
    "legal_act": {
      "type": "object",
      "required": ["document_id", "jurisdiction"],
      "properties": {
        "document_id": { "type": "string", "minLength": 1 },
        "url": { "type": ["string", "null"] },
        "canonical_source_url": { "type": ["string", "null"] },
        "fallback_text_url": { "type": ["string", "null"] },
        "title": { "type": ["string", "null"] },
        "title_short": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] },
        "abbreviation": { "type": ["string", "null"] },
        "language": { "type": ["string", "null"] },
        "is_in_force": { "type": "boolean", "default": true },
        "type": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "regulation",
                "directive",
                "decision",
                "law",
                "declaration",
                "recommendation",
                "treaty",
                "commission_proposal",
                "announcement",
                "statute",
                "administrative_regulation",
                "other"
              ]
            },
            { "type": "null" }
          ]
        },
        "jurisdiction": {
          "type": "string",
          "enum": [
            "de",
            "fr",
            "it",
            "es",
            "nl",
            "be",
            "at",
            "pl",
            "cz",
            "hu",
            "ro",
            "se",
            "dk",
            "ie",
            "gb",
            "ch",
            "no",
            "tr",
            "us",
            "ca",
            "mx",
            "br",
            "cn",
            "in",
            "jp",
            "kr",
            "vn",
            "eu",
            "de_norms",
            "de_bw",
            "de_by",
            "de_be",
            "de_bb",
            "de_hb",
            "de_hh",
            "de_he",
            "de_mv",
            "de_ni",
            "de_nw",
            "de_rp",
            "de_sl",
            "de_sn",
            "de_st",
            "de_sh",
            "de_th",
            "other"
          ]
        },
        "enactment_date": { "type": ["string", "null"] },
        "entry_into_force_date": { "type": ["string", "null"] },
        "last_amendment_date": { "type": ["string", "null"] },
        "validity_date": { "type": ["string", "null"] },
        "publication_date": { "type": ["string", "null"] },
        "entity_type": {
          "oneOf": [
            { "type": "string", "enum": ["legal_act", "consolidated_act"] },
            { "type": "null" }
          ],
          "default": "legal_act"
        }
      },
      "additionalProperties": false
    },
    "legal_act_relations": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source_document_id", "target_document_id", "relation_type"],
            "properties": {
              "source_document_id": { "type": "string", "minLength": 1 },
              "target_document_id": { "type": "string", "minLength": 1 },
              "relation_type": { "type": "string", "minLength": 1 },
              "concerned_sections": {
                "oneOf": [
                  {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["subdivision_concerned"],
                      "properties": {
                        "subdivision_concerned": { "type": "string", "minLength": 1 },
                        "comment": { "type": ["string", "null"] }
                      },
                      "additionalProperties": false
                    }
                  },
                  { "type": "null" }
                ]
              }
            },
            "additionalProperties": false
          }
        },
        { "type": "null" }
      ]
    }
  },
  "additionalProperties": false
}
