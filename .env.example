# Konfiguration fuer die NRW-Datenpipeline
#
# WICHTIG: API-Keys gehoeren NICHT hierher.
# Den Google Gemini API-Key in n8n ablegen:
#   Settings → Credentials → Add Credential → Google Gemini(PaLM) API
# Diese Datei enthaelt nur unkritische Konfigurationswerte (n8n Variables).

# Absoluter Pfad fuer Ergebnisdateien.
# Empfohlen wenn n8n nicht aus dem Projektverzeichnis gestartet wird.
# Leer lassen = ~/.n8n/nrw-results
RESULTS_DIR=

# Webhook-URL fuer Alerts (optional).
# Wird bei Fehlerquote > 10 % und bei unerwarteten Workflow-Abbruechen
# als POST-Request angesprochen.
ALERT_WEBHOOK_URL=
