# n8n Variables (in n8n: Settings → Variables)
# Diese Variablen werden von den Workflow-Code-Nodes via $vars.NAME gelesen.

# LLM Enrichment – Google Gemini (optional; ohne Credential werden keine Summaries generiert)
# Empfohlene Methode: Credential in n8n anlegen (Settings → Credentials → Google Gemini(PaLM) API).
# Nach Import: "Call Gemini"-Node öffnen und das Credential manuell verknüpfen.
GOOGLE_AI_API_KEY=

# Absoluter Pfad fuer Ergebnisdateien. Empfohlen wenn n8n nicht aus dem
# Projektverzeichnis gestartet wird.
# Leer lassen = ~/.n8n/nrw-results
RESULTS_DIR=

# Webhook fuer Alerts bei Fehlerquote > 10 % (optional)
ALERT_WEBHOOK_URL=
